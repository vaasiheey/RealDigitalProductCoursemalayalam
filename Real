<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="light">
<title>RealDigitalProductCourse — Build & Sell Your Own Digital Product</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#15121C;
    --bg:#FFFFFF;
    --purple:#6D28D9;
    --purple-deep:#4C1D95;
    --purple-soft:#8B5CF6;
    --lavender:#EDE9FE;
    --green:#25D366;
    --green-deep:#1DA851;
    --line:#E7E2F5;
    --white:#FFFFFF;
    --muted:#5B5568;
    --muted-soft:#8A8393;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{
    scroll-behavior:smooth;
    background-color:#FFFFFF !important;
    min-height:100%;
    -webkit-text-size-adjust:100%;
    text-size-adjust:100%;
  }
  body{
    background-color:#FFFFFF !important;
    color:var(--ink);
    font-family:'Inter',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
    min-height:100vh;
    width:100%;
  }
  h1,h2,h3,.display{
    font-family:'Inter',sans-serif;
    line-height:1.05;
    letter-spacing:-0.02em;
  }
  .mono{
    font-family:'IBM Plex Mono',monospace;
    letter-spacing:0.02em;
  }
  a{text-decoration:none; color:inherit;}
  img{max-width:100%; display:block;}
  .wrap{max-width:640px; margin:0 auto; padding:0 28px;}

  /* ---------- Eyebrow pill ---------- */
  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    background:var(--lavender);
    padding:9px 20px;
    border-radius:999px;
    font-size:13px;
    font-weight:700;
    color:var(--purple-deep);
    text-transform:uppercase;
    letter-spacing:0.04em;
  }
  .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--purple);}

  /* ---------- Hero ---------- */
  .hero{padding-top:52px; padding-bottom:32px; text-align:center;}
  .hero .eyebrow{margin-bottom:24px;}
  .hero h1{
    font-size:34px;
    font-weight:800;
    color:var(--ink);
    margin-bottom:18px;
  }
  .hero h1 em{
    font-style:normal;
    font-weight:800;
    color:var(--purple);
  }
  .hero p.sub{
    font-size:16.5px;
    color:var(--muted);
    line-height:1.55;
    margin-bottom:28px;
    text-align:left;
  }
  .video-frame{
    position:relative;
    border-radius:18px;
    overflow:hidden;
    border:1px solid var(--line);
    box-shadow:0 18px 40px -18px rgba(109,40,217,0.35);
    background:#000;
    aspect-ratio:16/9;
    margin-bottom:22px;
  }
  .video-frame iframe{
    width:100%; height:100%; border:0; display:block;
  }
  .video-tag{
    position:absolute; top:14px; left:14px;
    background:var(--purple); color:#fff;
    font-size:11px; font-weight:700;
    padding:6px 12px; border-radius:999px;
    z-index:3;
  }

  /* ---------- CTA buttons ---------- */
  .cta-btn{
    display:flex; align-items:center; justify-content:space-between;
    background:var(--purple);
    color:#fff;
    padding:19px 24px;
    border-radius:999px;
    font-weight:700;
    font-size:16px;
    border:none;
    width:100%;
    cursor:pointer;
    transition:transform .15s ease, background .15s ease;
  }
  .cta-btn:active{transform:scale(0.98);}
  .cta-btn:hover{background:var(--purple-deep);}
  .cta-btn .arrow-circle{
    width:34px;height:34px;border-radius:50%;
    background:rgba(255,255,255,0.22);
    display:flex;align-items:center;justify-content:center;
    color:#fff;
    flex-shrink:0;
  }
  .cta-btn.whatsapp{
    background:var(--green);
    margin-bottom:12px;
  }
  .cta-btn.whatsapp:hover{background:var(--green-deep);}
  .cta-btn.whatsapp .arrow-circle{background:rgba(255,255,255,0.25);}
  .cta-sub{
    text-align:center;
    font-size:12.5px;
    color:var(--muted-soft);
    margin-top:10px;
  }

  /* ---------- Ticker ---------- */
  .ticker-section{
    background:var(--purple);
    padding:14px 0;
    overflow:hidden;
    margin:36px 0;
  }
  .ticker-track{
    display:flex;
    gap:48px;
    white-space:nowrap;
    animation:scroll-left 22s linear infinite;
    width:max-content;
  }
  @keyframes scroll-left{
    from{transform:translateX(0);}
    to{transform:translateX(-50%);}
  }
  .ticker-item{
    display:flex; align-items:center; gap:10px;
    color:#fff;
    font-size:13.5px;
  }
  .ticker-item .check{
    width:18px;height:18px;border-radius:50%;
    background:var(--green);
    color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-size:11px; font-weight:700; flex-shrink:0;
  }
  .ticker-item b{color:#fff; font-weight:700;}
  .ticker-item span.loc{color:#E3D6FA;}

  /* ---------- Section heading ---------- */
  .section{padding-top:44px; padding-bottom:44px;}
  .section-head{margin-bottom:28px;}
  .section-head h2{
    font-size:30px;
    font-weight:800;
    margin-bottom:12px;
  }
  .section-head p{
    color:var(--muted);
    font-size:15.5px;
    line-height:1.55;
  }

  /* ---------- Problem list ---------- */
  .problem-list{display:flex; flex-direction:column; gap:2px;}
  .problem-item{
    display:flex; align-items:flex-start; gap:14px;
    padding:16px 4px;
    border-bottom:1px solid var(--line);
    font-size:16px;
    font-weight:500;
  }
  .problem-item .x{
    width:22px;height:22px;border-radius:50%;
    border:1.5px solid #C4408A;
    color:#C4408A;
    display:flex;align-items:center;justify-content:center;
    font-size:12px; flex-shrink:0; margin-top:2px;
  }
  .solved-banner{
    background:var(--purple);
    color:#fff;
    border-radius:16px;
    padding:26px 24px;
    margin-top:22px;
    font-size:19px;
    font-weight:700;
    line-height:1.35;
  }
  .solved-banner em{color:#B8F5CE; font-style:normal;}

  /* ---------- Feature cards ---------- */
  .feature-card{
    background:var(--purple);
    color:#fff;
    border-radius:18px;
    padding:24px 22px;
    margin-bottom:16px;
    position:relative;
    overflow:hidden;
  }
  .feature-card::after{
    content:'';
    position:absolute; right:-40px; top:-40px;
    width:140px; height:140px;
    border-radius:50%;
    background:radial-gradient(circle, rgba(37,211,102,0.25), transparent 70%);
  }
  .feature-card .tag-num{
    font-family:'IBM Plex Mono',monospace;
    font-size:12px;
    color:#B8F5CE;
    margin-bottom:12px;
    display:block;
  }
  .feature-card h3{
    font-size:22px;
    font-weight:800;
    margin-bottom:10px;
  }
  .feature-card p{
    color:#E3D6FA;
    font-size:14.5px;
    line-height:1.55;
    margin-bottom:16px;
  }
  .feature-pill{
    display:inline-flex; align-items:center; gap:8px;
    background:rgba(255,255,255,0.14);
    border:1px solid rgba(255,255,255,0.22);
    padding:7px 14px;
    border-radius:999px;
    font-size:12.5px;
    color:#fff;
  }

  /* ---------- Pricing ---------- */
  .price-card{
    background:var(--ink);
    border-radius:22px;
    padding:32px 26px;
    color:#fff;
    position:relative;
    border:1px solid rgba(139,92,246,0.4);
  }
  .price-card .limited{
    font-size:12.5px;
    font-weight:700;
    letter-spacing:0.08em;
    color:var(--purple-soft);
    text-transform:uppercase;
    margin-bottom:18px;
    display:block;
  }
  .price-row{display:flex; align-items:baseline; gap:14px; margin-bottom:6px;}
  .price-old{
    font-family:'IBM Plex Mono',monospace;
    font-size:20px;
    color:#8A8393;
    text-decoration:line-through;
  }
  .price-new{
    font-size:52px;
    font-weight:800;
    color:#fff;
  }
  .price-note{
    color:#C9C2D9;
    font-size:13.5px;
    margin-bottom:24px;
  }
  .price-card .cta-btn{background:var(--purple); color:#fff;}
  .price-card .cta-btn:hover{background:var(--purple-deep);}
  .price-card .cta-btn .arrow-circle{background:rgba(255,255,255,0.22);}

  .includes-list{margin-top:26px; display:flex; flex-direction:column; gap:14px;}
  .includes-item{display:flex; align-items:flex-start; gap:12px; font-size:14.5px; color:#E3DDF0;}
  .includes-item .tick{
    width:20px;height:20px;border-radius:50%;
    background:var(--green); color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-size:11px; font-weight:700; flex-shrink:0; margin-top:1px;
  }

  /* ---------- Guarantee seal ---------- */
  .seal-section{
    display:flex; flex-direction:column; align-items:center;
    text-align:center;
    padding-top:52px; padding-bottom:52px;
  }
  .seal{
    width:168px; height:168px;
    border-radius:50%;
    background:var(--purple);
    color:#fff;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    position:relative;
    margin-bottom:26px;
    box-shadow:0 16px 32px -12px rgba(76,29,149,0.55);
  }
  .seal::before{
    content:'';
    position:absolute; inset:-10px;
    border-radius:50%;
    border:2px dashed rgba(109,40,217,0.35);
  }
  .seal .num{
    font-size:44px;
    font-weight:900;
    line-height:1;
  }
  .seal .lbl{
    font-family:'IBM Plex Mono',monospace;
    font-size:10.5px;
    letter-spacing:0.06em;
    text-transform:uppercase;
    margin-top:4px;
    max-width:110px;
  }
  .seal-section h3{
    font-size:23px;
    font-weight:800;
    margin-bottom:14px;
  }
  .seal-section p{
    color:var(--muted);
    font-size:14.5px;
    line-height:1.65;
    max-width:520px;
  }
  .seal-section p.terms{
    font-size:12.5px;
    color:var(--muted-soft);
    margin-top:14px;
    font-style:italic;
  }

  /* ---------- Comparison ---------- */
  .compare-wrap{
    border:1px solid var(--line);
    border-radius:18px;
    overflow:hidden;
    background:var(--white);
  }
  .compare-head{
    text-align:center;
    padding:16px;
    font-weight:700;
    font-size:15px;
    border-bottom:1px solid var(--line);
  }
  .compare-list{padding:6px 20px;}
  .compare-row{
    display:flex; align-items:center; gap:12px;
    padding:13px 0;
    border-bottom:1px solid var(--line);
    font-size:14.5px;
  }
  .compare-row:last-child{border-bottom:none;}
  .compare-row .mark-x{color:#C4408A; font-weight:700; width:18px;}
  .compare-with{
    background:var(--purple);
    border-radius:16px;
    margin:18px 16px 20px;
    padding:6px 12px;
  }
  .compare-with .compare-row{
    border-bottom:1px solid rgba(255,255,255,0.16);
    color:#fff;
  }
  .compare-with .mark-check{color:var(--green); font-weight:700; width:18px;}
  .with-label{
    text-align:center;
    color:var(--purple);
    font-weight:700;
    font-size:14px;
    padding:14px 0 4px;
  }

  /* ---------- Bonus prompts strip ---------- */
  .prompt-grid{display:flex; flex-direction:column; gap:14px;}
  .prompt-card{
    display:flex; justify-content:space-between; align-items:center;
    border:1px solid var(--line);
    background:var(--white);
    border-radius:14px;
    padding:16px 18px;
  }
  .prompt-card .p-name{font-weight:700; font-size:15px;}
  .prompt-card .p-desc{font-size:13px; color:var(--muted-soft); margin-top:3px;}
  .prompt-card .p-val{
    font-family:'IBM Plex Mono',monospace;
    background:var(--purple);
    color:#fff;
    font-size:12px;
    font-weight:600;
    padding:5px 10px;
    border-radius:8px;
    white-space:nowrap;
    margin-left:12px;
  }

  /* ---------- FAQ ---------- */
  .faq-item{
    border:1px solid var(--line);
    border-radius:14px;
    margin-bottom:12px;
    background:var(--white);
    overflow:hidden;
  }
  .faq-q{
    display:flex; justify-content:space-between; align-items:center;
    padding:18px 20px;
    font-weight:700;
    font-size:15.5px;
    cursor:pointer;
  }
  .faq-q .chev{transition:transform .2s ease; font-size:16px; color:var(--purple); flex-shrink:0; margin-left:12px;}
  .faq-item.open .faq-q .chev{transform:rotate(180deg);}
  .faq-a{
    max-height:0;
    overflow:hidden;
    transition:max-height .25s ease;
    padding:0 20px;
    font-size:14.5px;
    color:var(--muted);
    line-height:1.6;
  }
  .faq-item.open .faq-a{padding-bottom:20px;}

  /* ---------- Stats ---------- */
  .stats-bar{
    display:flex;
    border:1px solid var(--line);
    border-radius:16px;
    background:var(--white);
    overflow:hidden;
    margin:8px 0 0;
  }
  .stat{
    flex:1; text-align:center; padding:20px 8px;
    border-right:1px solid var(--line);
  }
  .stat:last-child{border-right:none;}
  .stat .n{
    font-size:25px; font-weight:800; color:var(--purple);
  }
  .stat .l{font-size:11.5px; color:var(--muted-soft); margin-top:2px;}

  /* ---------- Sticky bottom bar ---------- */
  .sticky-bar{
    position:fixed; bottom:0; left:0; right:0;
    background:var(--ink);
    padding:12px 16px calc(12px + env(safe-area-inset-bottom));
    display:flex; align-items:center; gap:14px;
    z-index:50;
    transform:translateY(100%);
    transition:transform .3s ease;
    border-top:1px solid rgba(139,92,246,0.35);
  }
  .sticky-bar.show{transform:translateY(0);}
  .sticky-bar .sp{flex:1; color:#fff;}
  .sticky-bar .sp .sold{font-family:'IBM Plex Mono',monospace; font-size:11px; color:#8A8393; text-decoration:line-through;}
  .sticky-bar .sp .snew{font-size:19px; font-weight:800;}
  .sticky-bar a.cta-btn{width:auto; padding:13px 20px; font-size:14px;}

  footer{
    text-align:center;
    padding:36px 24px 90px;
    color:var(--muted-soft);
    font-size:12.5px;
  }
  footer .domain{
    font-family:'IBM Plex Mono',monospace;
    color:var(--purple);
    font-weight:700;
  }

  @media(min-width:600px){
    .hero h1{font-size:50px;}
  }
</style>
</head>
